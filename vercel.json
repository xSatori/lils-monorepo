{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "outputDirectory": "apps/web/dist",
  "routes": [
    {
      "src": "/discord",
      "status": 307,
      "headers": {
        "Location": "https://discord.gg/X6gpawuBaX"
      }
    },
    {
      "src": "/docs",
      "status": 307,
      "headers": {
        "Location": "https://nouns.notion.site/Explore-Nouns-a2a9dceeb1d54e10b9cbf3f931c2266f"
      }
    },
    {
      "src": "/api/ponder/graphql",
      "dest": "https://graphql.lilnouns.wtf/"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
